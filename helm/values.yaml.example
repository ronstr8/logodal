# Global settings shared across all microservices
global:
  domain: your-domain.example.com
  # The single port for all traffic (Frontend, API, WS)
  externalPort: 80
  registry: localhost:5000
  namespace: logodal
  projectName: "logodal"
  imageTag: latest
  imagePullPolicy: Always
  maxPlayers: 13
  randomLetterScoreMode: "true"
  gameDuration: 30
  quickBonusSeconds: 10
  uniqueWordBonus: 1
  rackSize: 8
  minVowels: 2
  minConsonants: 2
  logLevel: info
  defaultLanguage: en
  chatHistorySize: 50
  totalTiles: 100
  kofiId: "your-kofi-id"
  kofiEnabled: false
  paypalEnabled: false
  paypalEmail: "your-email@example.com"
  projectCodeLink: "https://github.com/your-org/logodal"
  scoreAgainstAI: "true"
  endOnAllPlayed: "false"
  redisUrl: "redis://redis-master:6379"
  storageClass: "standard"
  persistence:
    manualPV: false


# Centralized Ingress configuration
ingress:
  enabled: true
  host: your-domain.example.com
  annotations:
    kubernetes.io/ingress.class: nginx
    nginx.ingress.kubernetes.io/ssl-redirect: "false"
  tls:
    enabled: false
    secretName: logodal-tls

# Subchart overrides
frontend:
  enabled: true
  service:
    type: ClusterIP
    port: 80

wordd:
  enabled: true
  service:
    type: ClusterIP
    port: 2345
  langs: "en,es,fr,de,ru"

backend:
  enabled: true
  service:
    port: 3000
  ollama:
    url: "http://ollama:11434"
    model: "phi3:mini"
  database:
    url: "dbi:Pg:dbname=logodal;host=postgresql"
    user: "logodal_backend"
  env:
    ADMIN_SMS_EMAIL: ""
    CHAT_HISTORY_SIZE: 50
    OLLAMA_URL: "http://ollama:11434"
    OLLAMA_MODEL: "phi3:mini"

# PostgreSQL dependency configuration
postgresql:
  enabled: true
  fullnameOverride: postgresql
  image:
    registry: "docker.io"
    repository: "bitnamilegacy/postgresql"
    tag: "16.4.0-debian-12-r0"
  auth:
    database: "logodal"
    username: "logodal_backend"
  primary:
    initdb:
      scriptsConfigMap: db-init
    persistence:
      enabled: true
      size: 10Gi
  volumePermissions:
    enabled: true
    image:
      repository: busybox
      tag: 1.36.1

redis:
  enabled: true
  fullnameOverride: redis
  architecture: standalone
  auth:
    enabled: false
  master:
    persistence:
      enabled: false
  replica:
    replicaCount: 0

auth:
  sessionSecret: "change-me-to-a-long-random-secret"
  google:
    clientId: ""
    clientSecret: ""
  discord:
    clientId: ""
    clientSecret: ""
  notifications:
    discordWebhook: ""

ollama:
  enabled: false
  image:
    repository: localhost:5000/logodal-ollama
  service:
    type: ClusterIP
    port: 11434
  resources:
    limits:
      cpu: "4"
      memory: "4Gi"
    requests:
      cpu: "2"
      memory: "2Gi"
